{
  "version": "1.0.0",
  "description": "密钥/凭证检测模式库 — 覆盖云服务、数据库、第三方 API、加密密钥等 20+ 种常见凭证格式",
  "lastUpdated": "2026-07-17",
  "scanConfig": {
    "MAX_FILE_SIZE_BYTES": 1048576,
    "ENTROPY_THRESHOLD": 4.5,
    "MIN_STRING_LENGTH_FOR_ENTROPY": 16,
    "SKIP_EXTENSIONS": [".png", ".jpg", ".jpeg", ".gif", ".ico", ".exe", ".dll", ".bin", ".lock", ".min.js", ".min.css"],
    "SKIP_PATHS": [".git/", "node_modules/", ".next/", "dist/", "build/", "__pycache__/", ".venv/"]
  },

  "patterns": {
    "AI/LLM": [
      {
        "id": "SEC-001",
        "name": "Anthropic API Key",
        "regex": "sk-ant-(?:api|admin|chat|code)-[A-Za-z0-9]{32,}",
        "severity": "CRITICAL",
        "description_cn": "Anthropic/Claude API 密钥，可用于调用 Claude 模型"
      },
      {
        "id": "SEC-002",
        "name": "OpenAI API Key",
        "regex": "sk-(?:proj-)?[A-Za-z0-9-_]{32,}",
        "severity": "CRITICAL",
        "description_cn": "OpenAI API 密钥，可用于调用 GPT/DALL-E 等模型",
        "context_skip": "sk-proj-(?!.+)"
      },
      {
        "id": "SEC-003",
        "name": "DeepSeek API Key",
        "regex": "sk-[a-z0-9]{32}",
        "severity": "CRITICAL",
        "description_cn": "DeepSeek API 密钥"
      },
      {
        "id": "SEC-004",
        "name": "Google AI API Key",
        "regex": "AIza[0-9A-Za-z\\-_]{35}",
        "severity": "CRITICAL",
        "description_cn": "Google AI / Gemini API 密钥"
      }
    ],

    "Cloud": [
      {
        "id": "SEC-010",
        "name": "AWS Access Key ID",
        "regex": "AKIA[0-9A-Z]{16}",
        "severity": "CRITICAL",
        "description_cn": "AWS IAM 访问密钥 ID，通常与 Secret Key 成对出现"
      },
      {
        "id": "SEC-011",
        "name": "AWS Secret Access Key",
        "regex": "(?i)aws.{0,20}(?:secret|key|pwd|password).{0,20}['\":\\s=]{1,3}\\s*['\"]?([0-9a-zA-Z/+]{40})['\"]?",
        "severity": "CRITICAL",
        "description_cn": "AWS 密钥，与 Access Key ID 配合使用",
        "note": "高误报风险，需配合上下文验证"
      },
      {
        "id": "SEC-012",
        "name": "Azure Connection String",
        "regex": "DefaultEndpointsProtocol=https;AccountName=[^;]+;AccountKey=[^;]+;EndpointSuffix=",
        "severity": "CRITICAL",
        "description_cn": "Azure 存储连接字符串"
      },
      {
        "id": "SEC-013",
        "name": "GCP Service Account Key",
        "regex": "\"type\":\\s*\"service_account\"",
        "severity": "CRITICAL",
        "description_cn": "GCP 服务账号 JSON 密钥文件",
        "context_skip": "如果在 gitignore 的测试文件中 → 降级"
      }
    ],

    "Version Control": [
      {
        "id": "SEC-020",
        "name": "GitHub Personal Access Token (Classic)",
        "regex": "ghp_[A-Za-z0-9]{36}",
        "severity": "CRITICAL",
        "description_cn": "GitHub 个人访问令牌（经典版）"
      },
      {
        "id": "SEC-021",
        "name": "GitHub Personal Access Token (Fine-grained)",
        "regex": "github_pat_[A-Za-z0-9_]{36,}",
        "severity": "CRITICAL",
        "description_cn": "GitHub 细粒度访问令牌"
      },
      {
        "id": "SEC-022",
        "name": "GitLab Personal Access Token",
        "regex": "glpat-[A-Za-z0-9\\-_]{20,}",
        "severity": "CRITICAL",
        "description_cn": "GitLab 个人访问令牌"
      },
      {
        "id": "SEC-023",
        "name": "GitHub OAuth App Secret",
        "regex": "ghs_[A-Za-z0-9]{36}",
        "severity": "CRITICAL",
        "description_cn": "GitHub OAuth App 密钥"
      }
    ],

    "Database": [
      {
        "id": "SEC-030",
        "name": "MySQL Connection String",
        "regex": "(?i)mysql://[^:]+:[^@]+@[^/]+/\\w+",
        "severity": "HIGH",
        "description_cn": "MySQL 连接字符串（含密码）"
      },
      {
        "id": "SEC-031",
        "name": "PostgreSQL Connection String",
        "regex": "(?i)postgres(?:ql)?://[^:]+:[^@]+@[^/]+/\\w+",
        "severity": "HIGH",
        "description_cn": "PostgreSQL 连接字符串（含密码）"
      },
      {
        "id": "SEC-032",
        "name": "MongoDB Connection String",
        "regex": "(?i)mongodb(?:\\+srv)?://[^:]+:[^@]+@",
        "severity": "HIGH",
        "description_cn": "MongoDB 连接字符串（含密码）"
      },
      {
        "id": "SEC-033",
        "name": "Redis Connection String",
        "regex": "(?i)redis://[^:]+:[^@]+@",
        "severity": "HIGH",
        "description_cn": "Redis 连接字符串（含密码）"
      }
    ],

    "Private Keys": [
      {
        "id": "SEC-040",
        "name": "SSH Private Key",
        "regex": "-----BEGIN\\s+(RSA|DSA|EC|OPENSSH|PGP)\\s+PRIVATE\\s+KEY-----",
        "severity": "CRITICAL",
        "description_cn": "SSH 私钥文件内容"
      },
      {
        "id": "SEC-041",
        "name": "PEM Certificate Private Key",
        "regex": "-----BEGIN\\s+PRIVATE\\s+KEY-----",
        "severity": "CRITICAL",
        "description_cn": "PEM 格式私钥"
      },
      {
        "id": "SEC-042",
        "name": "JWT Signing Secret",
        "regex": "(?i)(?:jwt|token).{0,10}(?:secret|signing).{0,10}['\":\\s=]{1,3}\\s*['\"]?([A-Za-z0-9+/=]{32,})['\"]?",
        "severity": "HIGH",
        "description_cn": "JWT 签名密钥（硬编码）"
      }
    ],

    "Generic": [
      {
        "id": "SEC-050",
        "name": "Generic Password Assignment",
        "regex": "(?i)(?:password|passwd|pwd|secret)\\s*[:=]\\s*['\"](?!.*(?:\\$\\{|%|env|process\\.env|your|example|test|xxx|placeholder))[^'\"]{4,}['\"]",
        "severity": "HIGH",
        "description_cn": "硬编码密码（含上下文过滤）"
      },
      {
        "id": "SEC-051",
        "name": "Generic API Key Assignment",
        "regex": "(?i)(?:api[_-]?key|apikey|api[_-]?secret|api[_-]?token|access[_-]?key|auth[_-]?token)\\s*[:=]\\s*['\"](?!.*(?:\\$\\{|%|env|process\\.env|your|example|xxx))[^'\"]{8,}['\"]",
        "severity": "HIGH",
        "description_cn": "通用 API 密钥赋值"
      },
      {
        "id": "SEC-052",
        "name": "High Entropy String",
        "regex": null,
        "severity": "MEDIUM",
        "description_cn": "高熵值字符串（Shannon entropy > 4.5），可能是密钥/Token",
        "entropy_check": true,
        "entropy_threshold": 4.5,
        "min_length": 20
      },
      {
        "id": "SEC-053",
        "name": "Slack Webhook URL",
        "regex": "https://hooks\\.slack\\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]+",
        "severity": "HIGH",
        "description_cn": "Slack Webhook URL（含认证令牌）"
      }
    ],

    "China-Specific": [
      {
        "id": "SEC-060",
        "name": "阿里云 AccessKey",
        "regex": "LTAI[0-9A-Za-z]{16,20}",
        "severity": "CRITICAL",
        "description_cn": "阿里云 RAM 访问密钥"
      },
      {
        "id": "SEC-061",
        "name": "腾讯云 SecretId",
        "regex": "AKID[0-9A-Za-z]{32,48}",
        "severity": "CRITICAL",
        "description_cn": "腾讯云 API 密钥 ID"
      },
      {
        "id": "SEC-062",
        "name": "微信 AppSecret",
        "regex": "(?i)(?:appsecret|app_secret|appscret)\\s*[:=]\\s*['\"][0-9a-f]{32}['\"]",
        "severity": "CRITICAL",
        "description_cn": "微信公众号/小程序 AppSecret"
      },
      {
        "id": "SEC-063",
        "name": "百度 AI API Key",
        "regex": "(?i)(?:baidu|baiduai).{0,10}(?:api|access|secret).{0,10}['\":\\s=]{1,3}\\s*['\"]?([0-9a-zA-Z]{24,})['\"]?",
        "severity": "HIGH",
        "description_cn": "百度 AI 平台 API 密钥"
      }
    ]
  },

  "falsePositiveIndicators": {
    "description": "当匹配上下文包含以下信号时，自动降级严重度",
    "signals": [
      {"signal": "EXAMPLE_KEY", "action": "降级至 FALSE_POSITIVE", "description": "示例变量名"},
      {"signal": "your-*-here", "action": "降级至 FALSE_POSITIVE", "description": "占位符模式"},
      {"signal": "process.env.", "action": "降级至 MEDIUM", "description": "Node.js 环境变量引用"},
      {"signal": "$ENV_VAR / ${VAR}", "action": "降级至 MEDIUM", "description": "Shell 环境变量引用"},
      {"signal": "os.getenv(", "action": "降级至 MEDIUM", "description": "Python 环境变量引用"},
      {"signal": "System.getenv(", "action": "降级至 MEDIUM", "description": "Java 环境变量引用"},
      {"signal": "REPLACE_ME / TODO / FIXME", "action": "降级至 FALSE_POSITIVE", "description": "待办标记"},
      {"signal": "< 20 chars matched string", "action": "降级至 FALSE_POSITIVE", "description": "太短的字符串不可能是有效密钥"},
      {"signal": "在注释或文档中 (# // /* */ /** */)", "action": "降级一级", "description": "注释中的密钥不太可能是生产凭证"}
    ]
  }
}
